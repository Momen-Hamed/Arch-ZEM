{
  "$schema": "/etc/xdg/swaync/config.schema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 2,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 1,
  "control-center-margin-left": 0,
  "notification-icon-size": 48,
  "notification-body-image-height": 160,
  "notification-body-image-width": 90,
  "timeout": 6,
  "timeout-low": 4,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 380,
  "notification-window-width": 366,
  "keyboard-shortcuts": true,
  "image-visibility": "always",
  "transition-time": 100,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true
  "scripts": {
    "play-sound": {
      "exec": "mpv --volume=100 --no-video /home/cairo/Desktop/Work/C/windows-11-notify.mp3",
      "run-on": "receive"
    },
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "menubar",
    "buttons-grid",
    "volume",
    "mpris",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 6
    },
    "backlight": {
      "label": "уұӨЁ",
      "device": "intel_backlight",
      "min": 10
    },
    "backlight#KB": {
      "label": "п„ң ",
      "device": "asus::kbd_backlight",
      "subsystem": "leds"
    },
    "volume": {
      "label": "пҖЁ"
    },
    "menubar": {
      "menu#power-buttons": {
        "label": "пҖ‘",
        "position": "right",
        "actions": [
          {
            "label": "пҖЎ   Reboot",
            "command": "systemctl reboot"
          },
          {
            "label": "пҖЈ   Lock",
            "command": "playerctl pause; hyprlock"
          },
          {
            "label": "пӮӢ   Logout",
            "command": "loginctl terminate-session ${XDG_SESSION_ID-}"
          },
          {
            "label": "пҖ‘   Shut down",
            "command": "systemctl poweroff"
          }
        ]
      },
      "menu#powermode-buttons": {
        "label": "уұӨҺ",
        "position": "right",
        "actions": [
          {
            "label": "Performance",
            "command": "powerprofilesctl set performance"
          },
          {
            "label": "Balanced",
            "command": "powerprofilesctl set balanced"
          },
          {
            "label": "Power-saver",
            "command": "powerprofilesctl set power-saver"
          }
        ]
      },
      "menu#screenshot-buttons": {
        "label": "уұҹІ",
        "position": "left",
        "actions": [
          {
            "label": "уұҹІ   Entire screen",
            "command": "swaync-client -cp && sleep 1 && hyprshot -m output"
          },
          {
            "label": "уұҹІ   Select a region",
            "command": "swaync-client -cp && sleep 1 && hyprshot -m region"
          },
          {
            "label": "уұҹІ   Open screenshot menu",
            "command": "swaync-client -cp && rofi-screenshot"
          },
          {
            "label": "уұҹІ   Open screenshot folder",
            "command": "exo-open $HYPRSHOT_DIR"
          }
        ]
      },
      "menu#screencast-buttons": {
        "label": "пҖҪ",
        "position": "left",
        "actions": [
          {
            "label": "пҖҪ   Entire screen",
            "command": "swaync-client -cp && sleep 1 && recording.sh toggle fullscreen"
          },
          {
            "label": "пҖҪ   Select a region",
            "command": "swaync-client -cp && sleep 1 && recording.sh toggle region"
          },
          {
            "label": "пҖҪ   Stop",
            "command": "swaync-client -cp && recording.sh stop"
          },
          {
            "label": "пҖҪ   Open screencast folder",
            "command": "$XDG_VIDEOS_DIR/Screencasts"
          }
        ]
      }
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "уұӨі",
          "command": "nm-connection-editor"
        },
        {
          "label": "оҳ•",
          "command": "nwg-look"
        },
        {
          "label": "о—ј",
          "command": "nautilus"
        },
        {
          "label": "пүҙ",
          "command": "orage"
        },
        {
          "label": "пү©",
          "command": "firefox"
        },
        {
          "label": "уұЁҸ",
          "command": "brave"
        }
      ]
    }
  }
}
